! ####################################
! Verb grammar tables
! ####################################

! Note: if your game uses about 100+ bytes of array space in dynamic memory,
! the arrays below can be moved to static memory. They have to stay together,
! so either move all of them, or none of them.
! This has to do with https://intfiction.org/t/squashed-globals-in-z-code/72785

Array verb_grammar -->
	'inventory'    g_inv
	'i//'          g_inv
	'go'           g_go
	'take'         g_take
	'get'          g_get
	'open'         g_open
	'close'        g_close
	'lock'         g_lock
	'unlock'       g_unlock
	'drop'         g_drop
	'throw'        g_drop
	'insert'       g_insert
	'put'          g_put
	'push'         g_push
	'pull'         g_pull
	'examine'      g_examine
	'x//'          g_examine
	'read'         g_examine
	'search'       g_search
	'climb'        g_climb
	'look'         g_look
	'l//'          g_look
	'switch'       g_switch
	'wear'         g_wear
	'disrobe'      g_disrobe
	'turn'         g_turn
	'enter'        g_enter
	'exit'         g_exit
	'leave'        g_exit
	'ask'          g_ask
	'tell'         g_tell
	'answer'       g_answer
	'say'          g_answer
	'give'         g_give
	'show'         g_show
	'burn'         g_burn
	'light'        g_burn
	'cut'          g_cut
	'tie'          g_tie
	'attach'       g_tie
	'fasten'       g_tie
	'attack'       g_attack
	'kill'         g_attack
	'hit'          g_attack
	'hang'         g_hang    ! Added for Cloak of Darkness
	'wait'         g_wait
	'score'        g_score
	'z//'          g_wait
	'save'         g_save
	'restore'      g_restore
	'restart'      g_restart
	'quit'         g_quit
	'q//'          g_quit;
	
#Ifdef OPTIONAL_FULL_SCORE;
Array _full_score_grammar -->
	'full'         g_fullscore
	'fullscore'    g_fullscore;
#Endif;

#Ifndef NO_PLACES;
Array _places_grammar -->
	'places'       g_places
	'objects'      g_objects;
#Endif;

#Ifdef OPTIONAL_SCRIPT;
Array _script_grammar -->
	'script'       g_script
	'transcript'   g_script
	'noscript'     g_noscript
	'unscript'     g_noscript
	'recording'    g_recording
	'replay'       g_replay;
#Endif;

#Ifdef DEBUG;
Array _debug_grammar -->
	'scope'        g_scope
	'purloin'      g_purloin
	'gonear'       g_gonear
	'tree'         g_tree
	'forest'       g_forest
	'goto'         g_goto
	'rooms'        g_rooms
	'actions'      g_actions
	'routines'     g_routines
	'timers'       g_timers
	'daemons'      g_timers
;
#Endif;

Array _verb_grammar_end -->
	0 0; ! This marks the end of the table

! ####################################
!  Messages
! ####################################

Constant MSG_DONT_UNDERSTAND 10;
Constant MSG_PROMPT 11;
Constant MSG_OK 100;
Constant MSG_DOOR_CLOSED 101;
Constant MSG_TAKE_BELONGS 102;
Constant MSG_TAKE_PART_OF 103;
Constant MSG_OBJ_NOT_OPEN 104;
Constant MSG_NOT_HOLDING 105;
Constant MSG_ARE_YOU_SURE 106;
Constant MSG_YES_OR_NO 107;
Constant MSG_MISSING_NOUN 108;
Constant MSG_EXIT 109;
Constant MSG_AUTO_TAKE 110;
#Ifndef NO_SCORE;
Constant MSG_PARSER_NEW_SCORE 111;
#Endif;
Constant MSG_SCORE_DEFAULT 112;
#Ifdef OPTIONAL_FULL_SCORE;
Constant MSG_FULLSCORE_START 113;
Constant MSG_FULLSCORE_END 114;
#Endif;
Constant MSG_YOU_HAVE_WON 115;
Constant MSG_YOU_HAVE_DIED 116;
Constant MSG_RESTART_RESTORE_OR_QUIT 117;
Constant MSG_EXAMINE_NOTHING_SPECIAL 118;

Constant MSG_NO_MATCHING_OBJECT "I can't see what you're referring to.";
Constant MSG_BE_MORE_SPECIFIC "You have to be more specific.";
Constant MSG_FAILED "Failed.";
Constant MSG_ABSURD "That's absurd!";
Constant MSG_FUTILE "That seems futile.";
Constant MSG_NOT_POLITE "That wouldn't be very polite.";
Constant MSG_UNKNOWN_VERB "I don't know that verb.";
Constant MSG_NO_TOPIC "That sentence seems to lack a clear topic.";
Constant MSG_IS_STATIC "It's fixed in place.";
Constant MSG_NOTHING_HAPPENS "Nothing happens.";
Constant MSG_NOT_SWITCHABLE "That's not something you can switch.";
Constant MSG_NOT_LOCKABLE "That doesn't even seem lockable.";
Constant MSG_TELL_ME_HOW "You'd have to tell me how to do that.";
Constant MSG_DOESNT_FIT_LOCK "That doesn't fit the lock.";
Constant MSG_WHICH_KEY "You'd need to tell me which key to use.";
Constant MSG_TAKE_NOT_AVAILABLE "That's not available.";
Constant MSG_ONLY_ANIMATE "You can only do that to something animate.";
Constant MSG_NO_REPLY "There is no reply.";
Constant MSG_GIVE_DEFAULT "Your offer is quietly ignored.";
Constant MSG_ATTACK_DEFAULT "Violence isn't the answer here.";
Constant MSG_ACHEIVE_NOTHING "You would achieve nothing by this.";
#Ifdef OPTIONAL_DARKNESS;
Constant MSG_NOW_DARK "It's now completely dark.";
Constant MSG_ITS_DARK "But it's dark.";
#Endif;

#Ifdef OPTIONAL_FULL_SCORE;
#Ifdef OPTIONAL_SCORED;
#Ifndef MSG_FULLSCORE_OBJECTS;
Constant MSG_FULLSCORE_OBJECTS "finding sundry items";
#Endif;
#Ifndef MSG_FULLSCORE_ROOMS;
Constant MSG_FULLSCORE_ROOMS "visiting various places";
#Endif;
#Endif;
#Ifndef MSG_FULLSCORE_ACTIONS;
Constant MSG_FULLSCORE_ACTIONS "performing noteworthy actions";
#Endif;
#Endif;

[ _PrintMsg p_msg p_arg_1 p_arg_2;
	if(IsAString(p_msg))
		print_ret (string) p_msg;
	switch(p_msg) {
	MSG_DONT_UNDERSTAND:
		"I didn't understand that sentence.";
	MSG_PROMPT:
		print "^> "; rtrue;
	MSG_OK: 
		"Ok.";
	MSG_EXAMINE_NOTHING_SPECIAL:
		"You find nothing special about ", (the) p_arg_1, ".";
	MSG_AUTO_TAKE:
		"(first taking ", (the) p_arg_1, ")";
	MSG_NOT_HOLDING:
		"You're not holding ", (the) p_arg_1, ".";
	MSG_DOOR_CLOSED:
		"You hit your head against ", (the) p_arg_1, " as you attempt this.";
	MSG_TAKE_BELONGS:
		! p_arg_1 = the object that is held by p_arg_2
		"That seems to belong to ", (the) p_arg_2, ".";
	MSG_TAKE_PART_OF:
		! p_arg_1 = the object that is part of p_arg_2
		"That seems to be part of ", (the) p_arg_2, ".";
	MSG_OBJ_NOT_OPEN:
	! p_arg_1 = the object which isn't open.
		print_ret (CObjIs) p_arg_1, "n't open.";
	MSG_MISSING_NOUN:
		"You mean ~",(string) p_arg_1," *something*~?";
	MSG_EXIT:
		"You'd need to leave ",(the) p_arg_1," first.";
#Ifndef NO_SCORE;
	MSG_PARSER_NEW_SCORE:
		! p_arg_1 = the old score
		print "^[The score has just gone ";
		if(p_arg_1 < score) {
			p_arg_2 = score - p_arg_1;
			print "up";
		} else {
			p_arg_2 = p_arg_1 - score;
			print "down";
		}
		print " by ", p_arg_2, " point";
		if(p_arg_2 > 1) print "s";
		".]";
#Endif;
	MSG_SCORE_DEFAULT:
#Ifdef NO_SCORE;
		"There is no score in this game.";
#Ifnot;
		if (deadflag) print "In that game you"; else print "You have so far";
		print " scored ", score, " out of a possible ", MAX_SCORE, ", in ", turns, " turn";
		if(turns ~= 1) print "s";
		rtrue;
#Endif;
#IfDef OPTIONAL_FULL_SCORE;
	MSG_FULLSCORE_START:
		print "The score ";
		if(deadflag) print "wa"; else print "i";
		"s made up as follows:";
	MSG_FULLSCORE_END:
		"total (out of ", MAX_SCORE, ")";
#EndIf;
	MSG_ARE_YOU_SURE:
		print "Are you sure? "; rtrue;
	MSG_YES_OR_NO:
		print "Please answer yes or no: "; rtrue;
	MSG_YOU_HAVE_WON: ! print and rtrue to avoid newline
 		print "You have won";
 		rtrue;
	MSG_YOU_HAVE_DIED: ! print and rtrue to avoid newline
		print "You have died";
		rtrue;
	MSG_RESTART_RESTORE_OR_QUIT:
		print "^Would you like to RESTART, RESTORE";
#IfDef OPTIONAL_FULL_SCORE;
		print ", give the FULL score for that game";
#EndIf;
#Ifdef AMUSING_PROVIDED;
		if(deadflag == GS_WIN) print ", see some suggestions for AMUSING things to do";
#Endif;
		print " or QUIT? ";
		rtrue;
	}
#Iftrue RUNTIME_ERRORS > RTE_MINIMUM;
	_RunTimeError(ERR_UNKNOWN_MSG);
	print "Value: ", p_msg;
#Endif;
];

