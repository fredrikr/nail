! ####################################
!  Grammar
! ####################################

[ ImplicitGrabIfNotHeld p_noun _ks;
	! return true if p_noun isn't held by the player at the end of the call
	! (so that you can use it like: if(_ImplicitGrabIfNotHeld(...)) { }
	! Return false if actor isn't player or p_noun is 0
	@je p_noun 0 ?rfalse;
	if(p_noun in player) rfalse;
!	PronounNotice(p_noun);
	if(no_implicit_actions) { PrintMsg(MSG_NOT_HOLDING, p_noun); rtrue; }
	PrintMsg(MSG_AUTO_TAKE, p_noun);
	_ks = keep_silent;
	keep_silent = true;
	<Take p_noun>;
!	PerformAction(##Take, p_noun);
	keep_silent = _ks;
	if (p_noun notin player) rtrue;
	rfalse;
];

[ BlockIfWorn p_obj;
	if(p_obj == 0 || p_obj notin player || p_obj hasnt worn) rfalse;
	"Not while wearing ", (the) p_obj, ".";
];

[ QuitSub;
	PrintMsg(MSG_ARE_YOU_SURE);
	if(YesOrNo()) {
		print "Goodbye.^";
		deadflag = GS_QUIT;
	} else
		rtrue;
];

[ RestartSub;
	PrintMsg(MSG_ARE_YOU_SURE);
	if(YesOrNo()) {
		@restart;
		return MSG_FAILED;
	}
];

[ RestoreSub;
	@restore ?_restore_was_successful; ! can't use @restore because of compiler test
	return MSG_FAILED;
._restore_was_successful;
! This is never reached, since a successful restore continues after save opcode.
	rtrue;
];

[ SaveSub;
	@save ?_save_was_successful;
	return MSG_FAILED;
._save_was_successful;
	return MSG_OK;
];

[ Look _ceil _obj _result _msg _action;

!	_ceil = ScopeCeiling(player);
	_ceil = location;

#IfDef OPTIONAL_SCORED;
	if(location has scored && location hasnt visited) {
		score = score + ROOM_SCORE;
#IfDef OPTIONAL_FULL_SCORE;
		places_score = places_score + ROOM_SCORE;
#EndIf;
	}
#EndIf;
	new_line;
	_PrintObjName(location);

	_obj = parent(player);
#Ifdef OPTIONAL_DARKNESS;
	if(location == thedark) {
		_obj = location;
	}
#Endif;
	if(_obj ~= location) {
		if(_obj has supporter) print " (On "; else print " (In ";
		print (the) _obj;
		print ")";
	}
	new_line;
	if((lookmode == 1 && location hasnt visited) || lookmode == 2)
		PrintOrRun(location, description);
#Ifdef OPTIONAL_DARKNESS;
	if(location == thedark) {
		jump _EndOfLookRoutine;
	}
#Endif;

	also_flag = false;
	! write intial and describe messages in a new paragraph
	objectloop(_obj in _ceil)
		if(_obj hasnt scenery or concealed && _obj ~= player) {
			give _obj workflag;
			if(_obj.&describe) {
				_result = PrintOrRun(_obj, describe);
				if(_result) {
					give _obj ~workflag;
					if(_result ~= 2) also_flag = true;
					continue;
				}
			}
			if(_obj.&initial && _obj hasnt moved) {
				give _obj ~workflag;
				new_line;
				PrintOrRun(_obj, initial);
				also_flag = true;
			}
		}

	_msg = "^You can see ";
	if(also_flag) _msg = "^You can also see ";
	
	if(PrintContents(_msg, _ceil, WORKFLAG_BIT)) print " here.^";

._EndOfLookRoutine;
#Ifdef LookRoutine;
	! finally, call the optional library entry routine
	LookRoutine();
#Endif;
	_action = action; action = ##Look;
	AfterRoutines();
	action = _action;

	give location visited;
];

[ LookSub _old_lookmode;
	_old_lookmode = lookmode;
	lookmode = 2; ! force long description
	Look();
	lookmode = _old_lookmode;
];

#Ifdef OPTIONAL_LOOKMODE;
[ LookModeSub;
	meta = true;
	switch(parse-->3) {
		'brief', 'normal': lookmode = 1;
		'verbose', 'long': lookmode = 2;
		'superbrief', 'short': lookmode = 3;
	}
	return MSG_OK;
];
#Endif;

[ WaitSub;
	run_after_routines_msg = "Time passes.";
];

[ ExamineSub;
#Ifdef OPTIONAL_DARKNESS;
	if(location == thedark) return MSG_ITS_DARK;
#Endif;
	if(noun.description == 0 or NULL) 
		PrintMsg(MSG_EXAMINE_NOTHING_SPECIAL, noun);
	else
		RunRoutines(noun, description);
	run_after_routines_msg = 1;
];

[ _SearchSubText p_obj;
	if(p_obj has supporter)
		print "On ";
	else
		print "In ";
	print (ItOrThem) p_obj, ", you find ";
];

[ SearchSub;
#Ifdef OPTIONAL_DARKNESS;
	if(location == thedark) return MSG_ITS_DARK;
#Endif;
	if (ObjectIsUntouchable(noun)) return;
	if(noun hasnt supporter or container)
		return "You find nothing special.";
		
	if(noun has container && noun hasnt transparent && noun hasnt open)
		print_ret (CObjIs) noun, " closed.";

	if(PrintContents(_SearchSubText, noun)) 
		print ".^";
	else
		print (CObjIs) noun, " empty.^";
	
	run_after_routines_msg = 1;
];


[ TakeSub _parent _container_or_supporter;
	if(CommonAncestor(player, noun) == 0 || noun has animate or scenery)
		return MSG_ABSURD;
	if(noun has static) return MSG_IS_STATIC;
	if(noun in player) "You already have that.";
	if(ObjectIsUntouchable(noun, false, true)) rtrue;
	if(IndirectlyContains(noun, player)) { PrintMsg(MSG_EXIT, noun); rtrue; }

	_parent = parent(noun);
	if(_parent && _parent has container or supporter)
		_container_or_supporter = true;
	if(_container_or_supporter && _RunFakeAction(_parent, ##LetGo, before)) 
		rtrue; 

	move noun to player;
	give noun ~worn ~concealed;
	update_moved = true;

	if(_container_or_supporter && _RunFakeAction(_parent, ##LetGo, after)) 
		rtrue; 

	run_after_routines_msg = MSG_OK;
];

[ TakeAllButSub _i _obj _loc _count;
	_loc = parent(player);
	GetScopeCopy();
	for(_i = 0: _i<scope_copy_objects: _i++) {
		_obj = scope_copy->_i;
		if(_obj in _loc && _obj ~= noun && 
				_obj hasnt scenery or static or animate or concealed) {
			_count++;
			if(keep_silent == 0) print (name) _obj, ": ";
			<Take _obj>;
		}
	}
	if(_count == 0) "There's nothing to take.";
	run_after_routines_msg = 1;
];

[ DropSub _parent _is_obj;
	if(noun == player) return MSG_ABSURD;
	if(noun notin player) { PrintMsg(MSG_NOT_HOLDING, noun); rtrue; }
	if(BlockIfWorn(noun)) rtrue;

	_parent = parent(player);
	if(_parent has container or supporter) {
		_is_obj = true;
		if(_RunFakeAction(_parent, ##Receive, before)) rtrue;
	}
	move noun to parent(player);
	give noun moved ~worn ~concealed;
#Ifdef OPTIONAL_DARKNESS;
	if(location == thedark)
		scope_modified = true;
#Endif;
	if(_is_obj && _RunFakeAction(_parent, ##Receive, after)) rtrue;

	run_after_routines_msg = MSG_OK;
];

[ DropAllButSub _i _obj _count; 
	GetScopeCopy();
	for(_i = 0: _i<scope_copy_objects: _i++) {
		_obj = scope_copy->_i;
		if(_obj in player && _obj ~= noun && _obj hasnt worn) {
			_count++;
			if(keep_silent == 0) print (name) _obj, ": ";
			<Drop _obj>;
		}
	}
	if(_count == 0) "There's nothing to drop.";
	run_after_routines_msg = 1;
];

[ WearSub;
	if(noun == player) return MSG_ABSURD;
	if(ImplicitGrabIfNotHeld(noun)) rtrue;
	if(noun has worn) return "Already worn.";
	if(noun hasnt clothing) return "That can't be worn.";
	give noun worn;
	run_after_routines_msg = MSG_OK;
];

[ DisrobeSub;
	if(noun == player) return MSG_ABSURD;
	if(noun notin player || noun hasnt worn) 
		"You're not wearing ",(ItOrThem) noun,".";
	if(noun hasnt clothing) return "That can't be worn.";
	give noun ~worn;
	run_after_routines_msg = MSG_OK;
];

[ _RunFakeAction p_obj p_action p_property _action _result;
#IfDef DEBUG;
	if(debug_flag & 1) print "[ ~", (name) p_obj, "~.", (property) p_property, "() ]^";
#EndIf;
	receive_action = action;
	_action = action; action = p_action;
	_result = RunRoutines(p_obj, p_property);
	action = _action;
	return _result;
];

[ InsertSub;
	if(noun == player) return MSG_ABSURD;
	if(ImplicitGrabIfNotHeld(noun)) rtrue;
	if(second hasnt container) { return "You can't put anything inside that."; }
	if(second hasnt open) { PrintMsg(MSG_OBJ_NOT_OPEN, second); rtrue; }
	if(BlockIfWorn(noun)) rtrue;

	if(_RunFakeAction(second, ##Receive, before)) rtrue; 

	move noun to second;

	if(_RunFakeAction(second, ##Receive, after)) rtrue; 

	run_after_routines_msg = MSG_OK;
];

[ PutOnSub;
	if(noun == player) return MSG_ABSURD;
	if(ImplicitGrabIfNotHeld(noun)) rtrue;
	if (ObjectIsUntouchable(second)) return;
	if(second hasnt supporter) { return "You can't put anything on that."; }
	if(BlockIfWorn(noun)) rtrue;

	if(_RunFakeAction(second, ##Receive, before)) rtrue; 

	move noun to second;

	if(_RunFakeAction(second, ##Receive, after)) rtrue; 

	run_after_routines_msg = MSG_OK;
];

[ ThrowAtSub;
	if(ImplicitGrabIfNotHeld(noun)) rtrue;
	if(second has supporter)
		<<PutOn noun second>>;
	if (ObjectIsUntouchable(second)) return;
	if(BlockIfWorn(noun)) rtrue;
	if(_RunFakeAction(second, ##ThrownAt, before)) rtrue;
	if(second has animate)
		return MSG_ATTACK_DEFAULT;
	return MSG_OK;
];

[ OpenSub;
	if(noun has open) "That's already open.";
	if(noun has locked) "That's locked.";
	if(noun hasnt openable) return MSG_TELL_ME_HOW;
	give noun open;
!	"You open ", (the) noun, ".";
	run_after_routines_msg = MSG_OK;
];

[ CloseSub;
	if(noun hasnt open) { PrintMsg(MSG_OBJ_NOT_OPEN, noun); rtrue; }
	if(noun hasnt openable) return MSG_TELL_ME_HOW;
	give noun ~open;
!	"You close ", (the) noun, ".";
	run_after_routines_msg = MSG_OK;
];

[ LockSub;
	if(noun hasnt lockable) return MSG_NOT_LOCKABLE;
	if(noun has open) "That's open.";
	if(noun has locked) "That's already locked.";
	if(second == 0) return MSG_WHICH_KEY;
	if(noun.with_key ~= second) return MSG_DOESNT_FIT_LOCK;
	give noun locked;
	run_after_routines_msg = MSG_OK;
];

[ UnlockSub;
	if(noun hasnt lockable) return MSG_NOT_LOCKABLE;
	if(noun hasnt locked) "That's not locked.";
	if(second == 0) return MSG_WHICH_KEY;
	if(noun.with_key ~= second) return MSG_DOESNT_FIT_LOCK;
	give noun ~locked;
	run_after_routines_msg = MSG_OK;
];

[ PushSub;
	if (ObjectIsUntouchable(noun)) return;
	if(noun has static) return MSG_IS_STATIC;
	if(noun has scenery || noun == player) return MSG_ABSURD;
	if(noun has animate) return MSG_NOT_POLITE;
	return MSG_NOTHING_HAPPENS;
];

[ PullSub;
	return PushSub();
];

[ TurnSub;
	return PushSub();
];

[ SwitchOnSub;
	if(noun hasnt switchable) return MSG_NOT_SWITCHABLE;
	if(noun has on) "That's already on.";
	give noun on;
	run_after_routines_msg = "You turn it on.";
];

[ SwitchOffSub;
	if(noun hasnt switchable) return MSG_NOT_SWITCHABLE;
	if(noun hasnt on) "That's already off.";
	give noun ~on;
	run_after_routines_msg = "You turn it off.";
];

[ GoSub _val _old_loc;
	_old_loc = real_location;
	_val = real_location.direction;
	if(_val < 2 || _val > top_object)
		_val = real_location.direction(); ! May be string or routine
	if(_val == 0)
		"There is no obvious exit in that direction.";		
	if(_val > 1 && _val <= top_object) {
		if(_val has door) {
			if(_val hasnt open) {
				run_after_routines_msg = MSG_DOOR_CLOSED;
				run_after_routines_arg_1 = _val;
				rtrue;
			}
			if(_val provides door_to) {
				_val = _val.door_to();
			} else {
				if(_val provides found_in && _val.#found_in == 4) {
					if(real_location == _val.&found_in-->0)
						_val = _val.&found_in-->1;
					else
						_val = _val.&found_in-->0;
				} else {
#Iftrue RUNTIME_ERRORS > RTE_MINIMUM;
					_RunTimeError(ERR_BROKEN_DOOR, _val);
#Endif;
				}
			}
			
		}
		if(_RunFakeAction(_val, ##Going, before)) rtrue;
		PlayerTo(_val,2);
		if(_RunFakeAction(_old_loc, ##Going, after)) rtrue;
		run_after_routines_msg = 1;
	}
];

[ InvSub;
	if(PrintContents("You are carrying ", player)) print ".^";
	else print "You are empty-handed.^";
	run_after_routines_msg = 1;
];

[ ClimbSub;
	if(noun == 0) { PrintMsg(MSG_MISSING_NOUN, "climb"); rtrue; }
	return MSG_ACHEIVE_NOTHING;
];

[ EnterSub _dir;
	if(noun == 0) { PrintMsg(MSG_MISSING_NOUN, "enter"); rtrue; }
	if(ObjectIsUntouchable(noun)) rtrue;
	if(IndirectlyContains(player, noun)) 
		"Certainly not while you're holding ", (ItOrThem) noun, ".";  
	if(player notin real_location) 
		"You'd have to leave ", (the) parent(player), " first.";
	if(noun hasnt door or container or supporter) return MSG_FUTILE;
	if(noun hasnt open && noun hasnt supporter) { PrintMsg(MSG_OBJ_NOT_OPEN, noun); rtrue; }
	if(noun has container or supporter) {
		if(noun hasnt enterable) return MSG_FUTILE;
		PlayerTo(noun, true);
		run_after_routines_msg = MSG_OK;
	} else if(noun provides door_dir) {
		if(noun.#door_dir == 4) {
			if(real_location == noun.&found_in-->0)
				_dir = noun.&door_dir-->0;
			else
				_dir = noun.&door_dir-->1;
		} else {
			_dir = RunRoutines(noun, door_dir);
		}
!		print "Going direction ", (property) _dir, ".";
		_dir = DirPropToFakeObj(_dir);
		<Go _dir>;
		run_after_routines_msg = 1;
	} else {
#Iftrue RUNTIME_ERRORS > RTE_MINIMUM;
		_RunTimeError(ERR_BROKEN_DOOR, noun);
#Endif;
	}
];

[ ExitSub _parent;
	if(noun == 0) {
		_parent = parent(player);
		if(_parent ~= real_location)
			noun = _parent;
		else { 
			PrintMsg(MSG_MISSING_NOUN, "leave"); 
			rtrue;
		}
	}
	if(~~(player in noun))
		"But you're not in or on ", (the) noun, ".";
	if(noun hasnt open && noun has container) { PrintMsg(MSG_OBJ_NOT_OPEN, noun); rtrue; }
	PlayerTo(real_location, true);
	run_after_routines_msg = MSG_OK;
];

[ AskSub;
	if(noun hasnt animate) return MSG_ONLY_ANIMATE;
	return MSG_NO_REPLY;
];

[ TellSub;
	return AskSub();
];

[ AnswerSub;
	if(noun == 0) "You do, to no one in particular.";
	return AskSub();
];

[ GiveSub;
	if(ObjectIsUntouchable(noun)) return;
	if(ImplicitGrabIfNotHeld(second)) rtrue;
	if (noun == player)  return MSG_OK;
	if(BlockIfWorn(second)) rtrue;
!	if (RunLife(second, ##Give) ~= 0) rfalse;
	return MSG_GIVE_DEFAULT;
];

[ ShowSub;
	if(ObjectIsUntouchable(noun)) return;
	if(ImplicitGrabIfNotHeld(second)) rtrue;
!	if (noun == player)  return MSG_OK;
!	if (RunLife(second, ##Give) ~= 0) rfalse;
	return MSG_NO_REPLY;
];

[ AttackSub;
	if(ImplicitGrabIfNotHeld(second)) rtrue;
	if (ObjectIsUntouchable(noun)) return;
!	if (noun has animate && RunLife(noun, ##Attack) ~= 0) rfalse;
	return MSG_ATTACK_DEFAULT;
];

[ _GeneralUselessAction;
	if(second && ImplicitGrabIfNotHeld(second)) rtrue;
	if (ObjectIsUntouchable(noun)) return;
	return MSG_ACHEIVE_NOTHING;
];

[ BurnSub;
	return _GeneralUselessAction();
];

[ CutSub;
	return _GeneralUselessAction();
];

[ TieSub;
	if (ObjectIsUntouchable(noun)) rtrue;
	if (second && ObjectIsUntouchable(second)) rtrue;
	return MSG_ACHEIVE_NOTHING;
];

#Ifdef NO_SCORE;
[ ScoreSub;
	return MSG_SCORE_DEFAULT;
];
#Ifnot;
#Ifndef PrintRank;
[ PrintRank; "."; ];
#Endif;
[ ScoreSub;
	PrintMsg(MSG_SCORE_DEFAULT);
	PrintRank();
];
#Endif;

#Ifdef OPTIONAL_FULL_SCORE;
#Ifdef TASKS_PROVIDED;
[ Achieved num;
	if (task_done->num == 0) {
		task_done->num = 1;
		score = score + task_scores->num;
	}
];
#Endif;
[ PANum p_m _n;
	print "  ";
	_n = p_m;
	if(_n < 0)    _n = -10 * p_m;
	if(_n < 10)   print " ";
	if(_n < 100)  print " ";
	if(_n < 1000) print " ";
._Panuml;
	print p_m, " ";
];
#Endif;

#Ifdef OPTIONAL_FULL_SCORE;
#Ifdef TASKS_PROVIDED;
[ FullScoreSub _i _score_sum _sc;
#Ifnot;
[ FullScoreSub _i _score_sum;
#Endif;
	new_line;
	PrintMsg(MSG_FULLSCORE_START);
#Ifdef TASKS_PROVIDED;
	for(_i=0 : _i<NUMBER_TASKS : _i++)
		if (task_done->_i == 1) {
			_sc = task_scores->(_i);
			PANum(_sc);
			_score_sum = _score_sum + _sc;
#Ifdef PrintTaskName;
			PrintTaskName(_i);
#Endif;
		}
#Ifnot;
	_i = 0; ! Avoid warning
#Endif;
#Ifdef OPTIONAL_SCORED;
	if(things_score ~= 0) {
		PANum(things_score);
		PrintMsg(MSG_FULLSCORE_OBJECTS);
	}
	if(places_score ~= 0) {
		PANum(places_score);
		PrintMsg(MSG_FULLSCORE_ROOMS);
	}
	_score_sum = score - _score_sum - things_score - places_score;
#Ifnot;
	_score_sum = score - _score_sum;
#Endif;
	if(_score_sum ~= 0) {
		PANum(_score_sum);
		PrintMsg(MSG_FULLSCORE_ACTIONS);
	}
	new_line;
	PANum(score);
	return MSG_FULLSCORE_END;
];
#Endif;

#Ifndef NO_PLACES;
[ PlacesSub _i;
	print "You have visited:^";
	objectloop(_i has visited) {
		if(parent(_i) == 0 && _RoomLike(_i)) {
#Ifdef OPTIONAL_DARKNESS;
			if(_i == thedark) continue;
#Endif;
			print "- ", (name) _i; new_line;
		}
	}
];

[ ObjectsSub _i _j _f;
	print "Objects you have handled: ";
	objectloop (_i has moved && _ObjectLike(_i)) {
		_j = parent(_i);
		if(_f == 0) new_line;
		_f++;
		print "- ", (the) _i, "   ";
		if (_j == player) {
			if (_i has worn) {
				print "(worn)";
			} else {
				print "(held)";
			}
		} else if(_j == 0) print "(lost)";
		else if(_j has animate) print "(given away)";
		else if(_j has visited && parent(_j)==0) print "(in ", (name) _j, ")";
		else if(_j has container) print "(inside ", (the) _j, ")";
		else if(_j has supporter) print "(on ", (the) _j, ")";
		else if(_j has enterable) print "(in ", (the) _j, ")";
		else print "(lost)";
		new_line;
	}
	if(_f == 0) "none.";
];

Array g_places static table [
	T_SET_META
	##Places
];

Array g_objects static table [
	T_SET_META
	##Objects
];

#Endif; ! NO_PLACES

Array g_quit static table [
	T_SET_META
	##Quit
];

Array g_restart static table [
	T_SET_META
	##Restart
];

Array g_save static table [
	T_SET_META
	##Save
];

Array g_restore static table [
	T_SET_META
	##Restore
];

Array g_wait static table [
	##Wait
];

#Ifdef OPTIONAL_LOOKMODE;
Array g_look static table [
	##Look
	##LookMode 'brief'
	##LookMode 'normal'
	##LookMode 'superbrief'
	##LookMode 'short'
	##LookMode 'verbose'
	##LookMode 'long'
	##Examine 'at' T_NOUN
];
#Ifnot;
Array g_look static table [
	##Look
	##Examine 'at' T_NOUN
];
#Endif;

Array g_take static table [
	##Take T_NOUN
	##TakeAllBut T_ALL
	##TakeAllBut T_ALL T_BUT T_NOUN
	##Disrobe 'off' T_NOUN
];

Array g_get static table [
	##Take T_NOUN
	##TakeAllBut T_ALL
	##TakeAllBut T_ALL T_BUT T_NOUN
	##Enter 'on' T_NOUN
	##Exit 'off' T_NOUN
	##Exit 'out' 'of' T_NOUN
];

Array g_exit static table [
	##Exit
	##Exit T_NOUN
];

Array g_wear static table [
	##Wear T_NOUN
];

Array g_disrobe static table [
	##Disrobe T_NOUN
];

Array g_open static table [
	##Open T_NOUN
];

Array g_close static table [
	##Close T_NOUN
];

Array g_lock static table [
	##Lock T_NOUN 'with' T_SECOND
	##Lock T_NOUN
];

Array g_unlock static table [
	##Unlock T_NOUN 'with' T_SECOND
	##Unlock T_NOUN
];

Array g_switch static table [
	##SwitchOn T_NOUN
	##SwitchOn 'on' T_NOUN
	##SwitchOn T_NOUN 'on'
	##SwitchOff 'off' T_NOUN
	##SwitchOff T_NOUN 'off'
];

Array g_turn static table [
	##Turn T_NOUN
	##SwitchOn 'on' T_NOUN
	##SwitchOn T_NOUN 'on'
	##SwitchOff 'off' T_NOUN
	##SwitchOff T_NOUN 'off'
];

Array g_push static table [
	##Push T_NOUN
];

Array g_pull static table [
	##Pull T_NOUN
];

Array g_drop static table [
	##Drop T_NOUN
	##DropAllBut T_ALL
	##DropAllBut T_ALL T_BUT T_NOUN
	##Insert T_NOUN 'in' T_SECOND
	##Insert T_NOUN 'into' T_SECOND
